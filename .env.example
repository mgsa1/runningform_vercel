# =============================================================================
# RunningForm — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local to Git.
# See comments in .env.local for where to find each key.
# =============================================================================

# Anthropic (server-side only)
ANTHROPIC_API_KEY=

# Supabase (server-side)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser-safe — same values as above without NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Inngest (server-side only — use "local" for local dev, real keys for production)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Sentry (optional, safe for browser)
NEXT_PUBLIC_SENTRY_DSN=
